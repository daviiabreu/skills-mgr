    esac
}

tool_display_name() {
    case "$1" in
        amp)      echo "AMP" ;;
        augment)  echo "Augment Code" ;;
        claude)   echo "Claude Code" ;;
        cline)    echo "Cline" ;;
        codex)    echo "Codex" ;;
        continue) echo "Continue" ;;
        copilot)  echo "GitHub Copilot" ;;
        cursor)   echo "Cursor" ;;
        factory)  echo "Factory/Droid" ;;
        gemini)   echo "Gemini CLI" ;;
        goose)    echo "Goose" ;;
        kilo)     echo "Kilo Code" ;;
        kiro)     echo "Kiro" ;;
        opencode) echo "OpenCode" ;;
        roo)      echo "Roo Code" ;;
        trae)     echo "Trae" ;;
        vscode)   echo "VS Code" ;;
        windsurf) echo "Windsurf" ;;
        zed)      echo "Zed" ;;
        *)        echo "$1" ;;
