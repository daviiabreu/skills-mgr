}

apply_tool() {
    GLOBAL_SKILLS=$(tool_global_dir "$TOOL_NAME")
    TOOL_PROJECT_SUBDIR=$(tool_project_subdir "$TOOL_NAME")
}

# True when the tool has a separate global dir (not same as source)
tool_has_global_control() {
    [[ "$GLOBAL_SKILLS" != "$SKILLS_SOURCE" ]]
}

# ---- Config ----

CONFIG_DIR="$HOME/.config/skills-mgr"
LEGACY_CONFIG_DIR="$HOME/.claude/skills-mgr"
PROJECTS_FILE=""
LANG_FILE=""
TOOL_FILE=""

resolve_config_dir() {
    if [[ -d "$LEGACY_CONFIG_DIR" && ! -d "$CONFIG_DIR" ]]; then
        mkdir -p "$(dirname "$CONFIG_DIR")"
        cp -r "$LEGACY_CONFIG_DIR" "$CONFIG_DIR"
    fi
    mkdir -p "$CONFIG_DIR"
    PROJECTS_FILE="$CONFIG_DIR/projects.conf"
    LANG_FILE="$CONFIG_DIR/lang.conf"
    TOOL_FILE="$CONFIG_DIR/tool.conf"
}

