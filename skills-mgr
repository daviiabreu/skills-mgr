load_strings() {
    case "$SKILLS_LANG" in
        pt) _strings_pt ;;
        *)  _strings_en ;;
    esac
}

# ---- Init ----

init() {
    resolve_config_dir
    [[ -f "$PROJECTS_FILE" ]] || touch "$PROJECTS_FILE"
    load_lang
    load_strings
    load_tool
}

load_tool() {
    if [[ -f "$TOOL_FILE" ]]; then
        TOOL_NAME=$(cat "$TOOL_FILE")
    else
        TOOL_NAME="claude"
    fi
    apply_tool
}

save_tool() {
    local tool="$1"
    case "$tool" in
        amp|augment|claude|cline|codex|continue|copilot|cursor|factory|gemini|goose|kilo|kiro|opencode|roo|trae|vscode|windsurf|zed) ;;
        *) echo "Valid tools: amp, augment, claude, cline, codex, continue, copilot, cursor, factory, gemini, goose, kilo, kiro, opencode, roo, trae, vscode, windsurf, zed"; return 1 ;;
    esac
    echo "$tool" > "$TOOL_FILE"
    TOOL_NAME="$tool"
    apply_tool
}

# ---- Helpers ----

get_category() {
    case "$1" in
        gws-*)     echo "gws" ;;
        recipe-*)  echo "recipe" ;;
        persona-*) echo "persona" ;;
        plugin-*)  echo "plugin" ;;
        writing-*) echo "writing" ;;
        *)         echo "other" ;;
    esac
}

list_available() { ls "$SKILLS_SOURCE" 2>/dev/null | sort; }

is_global_active() {
    [[ -L "$GLOBAL_SKILLS/$1" ]] || [[ -d "$GLOBAL_SKILLS/$1" && ! -L "$GLOBAL_SKILLS/$1" ]]
}

is_local_skill() {
    # When source = global (e.g. Codex), nothing is "local" — all come from source
    tool_has_global_control || return 1
    [[ -d "$GLOBAL_SKILLS/$1" && ! -L "$GLOBAL_SKILLS/$1" ]]
}

is_project_active() { [[ -L "$1/$TOOL_PROJECT_SUBDIR/$2" ]]; }

is_project_registered() { grep -qxF "$1" "$PROJECTS_FILE" 2>/dev/null; }

get_projects() { [[ -f "$PROJECTS_FILE" ]] && grep -v '^$' "$PROJECTS_FILE" 2>/dev/null || true; }

get_skill_description() {
    local md="$SKILLS_SOURCE/$1/SKILL.md"
    [[ -f "$md" ]] && awk '/^---$/{f++; next} f==1 && /^description:/{sub(/^description: */, ""); gsub(/^"|"$/, ""); print; exit}' "$md"
    return 0
}

count_global_active() {
    local c=0
    while read -r s; do is_global_active "$s" && c=$((c + 1)); done < <(list_available)
    echo "$c"
}

count_total() { list_available | wc -l | tr -d ' '; }

count_project_skills() {
    [[ -d "$1/$TOOL_PROJECT_SUBDIR" ]] && find "$1/$TOOL_PROJECT_SUBDIR" -maxdepth 1 -type l 2>/dev/null | wc -l | tr -d ' ' || echo 0
}

resolve_path() { (cd "$1" 2>/dev/null && pwd) || echo "$1"; }

enable_skill_global() {
    local skill="$1"
    # When source = global (e.g. Codex), all skills are already active
    tool_has_global_control || return 0
    is_global_active "$skill" && return 0
    [[ -d "$SKILLS_SOURCE/$skill" ]] || return 1
    mkdir -p "$GLOBAL_SKILLS"
    ln -sfn "$SKILLS_SOURCE/$skill" "$GLOBAL_SKILLS/$skill"
}

disable_skill_global() {
    local skill="$1"
    tool_has_global_control || return 1
    is_local_skill "$skill" && return 1
    is_global_active "$skill" || return 0
    rm "$GLOBAL_SKILLS/$skill"
}

enable_skill_project() {
    local project="$1" skill="$2" target="$project/$TOOL_PROJECT_SUBDIR"
    mkdir -p "$target"
    [[ -e "$target/$skill" ]] && return 0
    [[ -d "$SKILLS_SOURCE/$skill" ]] || return 1
    ln -sfn "$SKILLS_SOURCE/$skill" "$target/$skill"
}

disable_skill_project() {
    local target="$1/$TOOL_PROJECT_SUBDIR/$2"
    [[ -L "$target" ]] && rm "$target"
}

expand_target() {
    if [[ "$1" == @* ]]; then
        local cat="${1#@}"
        list_available | while read -r s; do [[ "$(get_category "$s")" == "$cat" ]] && echo "$s"; done
    else
        echo "$1"
    fi
}

register_project() {
    local p="$1"
    is_project_registered "$p" && return 0
    echo "$p" >> "$PROJECTS_FILE"
    mkdir -p "$p/$TOOL_PROJECT_SUBDIR"
}

wait_for_key() {
    echo ""
    echo -e "${DIM}${S_PRESS_ENTER}${NC}"
    read -r
}

# ---- TUI: Language ----

tui_select_language() {
    clear
    gum style --bold --foreground 212 "🌐  Select Language / Selecione o Idioma"
    echo ""

    local choice
    choice=$(gum choose --cursor "▸ " \
        "🇺🇸  English" \
        "🇧🇷  Português (pt-br)") || true
