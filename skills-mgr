# Supported: 19 AI coding agents (see tool_display_name for full list)

SKILLS_SOURCE="$HOME/.agents/skills"

# ---- Tool Profiles ----

TOOL_NAME="claude"
GLOBAL_SKILLS=""
TOOL_PROJECT_SUBDIR=""

tool_global_dir() {
    case "$1" in
        amp)      echo "$HOME/.amp/skills" ;;
        augment)  echo "$HOME/.augment/skills" ;;
        claude)   echo "$HOME/.claude/skills" ;;
        cline)    echo "$HOME/.cline/skills" ;;
        codex)    echo "$SKILLS_SOURCE" ;;
        continue) echo "$HOME/.continue/skills" ;;
