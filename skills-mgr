# ---- TUI: Header ----

header() {
    local total tool_display
    total=$(count_total)
    tool_display=$(tool_display_name "$TOOL_NAME")
    local proj_count
    proj_count=$(get_projects | grep -c . 2>/dev/null || echo 0)

    if tool_has_global_control; then
        local active; active=$(count_global_active)
        gum style --border rounded --border-foreground 212 --padding "0 2" --bold \
            "$(printf "$S_HEADER_FMT" "$tool_display" "$active" "$total" "$proj_count")"
    else
        gum style --border rounded --border-foreground 212 --padding "0 2" --bold \
            "$(printf "$S_HEADER_ALL_FMT" "$tool_display" "$total" "$proj_count")"
