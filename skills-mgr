}

# ---- TUI: Global Skills ----

tui_global_skills() {
    while true; do
        clear
        local total; total=$(count_total)

        if tool_has_global_control; then
            local active; active=$(count_global_active)
            gum style --bold --foreground 212 "$(printf "$S_GLOBAL_TITLE_FMT" "$active" "$total")"
        else
            gum style --bold --foreground 212 "$(printf "$S_GLOBAL_TITLE_ALL_FMT" "$total")"
        fi
        echo -e "${DIM}${S_ESC_HINT}${NC}"
        echo ""

        local options=("$S_GLOBAL_VIEW")
        if tool_has_global_control; then
            options+=("$S_GLOBAL_ENABLE" "$S_GLOBAL_DISABLE" "$S_GLOBAL_TOGGLE")
        fi

        local choice
        choice=$(gum choose --cursor "▸ " --height 10 \
            "${options[@]}") || true
        [[ -z "$choice" ]] && return

        case "$choice" in
            "📋"*)  tui_view_categories ;;
            "✅"*)  tui_enable_global ;;
            "⛔"*)  tui_disable_global ;;
            "🔄"*)  tui_toggle_category ;;
        esac
    done
}

tui_view_categories() {
    clear
    gum style --bold --foreground 212 "$S_CAT_TITLE"
    echo ""

    local cats
    cats=$(list_available | while read -r s; do get_category "$s"; done | sort -u)

    local items=()
    for cat in $cats; do
        local total=0 active=0
        while read -r s; do
            [[ "$(get_category "$s")" == "$cat" ]] || continue
            total=$((total + 1)); is_global_active "$s" && active=$((active + 1))
        done < <(list_available)
        items+=("$(printf '@%s  (%s)' "$cat" "$(printf "$S_ACTIVE_FMT" "$active" "$total")")")
    done

    local selected
    selected=$(printf '%s\n' "${items[@]}" | gum choose --cursor "▸ " --height 12) || true
    [[ -z "$selected" ]] && return
    local cat_name
    cat_name=$(echo "$selected" | awk '{print $1}' | sed 's/@//')

    tui_category_detail "$cat_name"
}

tui_category_detail() {
    local cat="$1"
    while true; do
        clear
        local total=0 active=0
        while read -r s; do
            [[ "$(get_category "$s")" == "$cat" ]] || continue
            total=$((total + 1)); is_global_active "$s" && active=$((active + 1))
        done < <(list_available)

        gum style --bold --foreground 212 "$(printf '@%s (%s)' "$cat" "$(printf "$S_ACTIVE_FMT" "$active" "$total")")"
        echo ""

        while read -r skill; do
            [[ "$(get_category "$skill")" == "$cat" ]] || continue
            local icon="○" color="$DIM"
            is_global_active "$skill" && icon="●" && color="$GREEN"
            local desc
            desc=$(get_skill_description "$skill")
            printf "  ${color}${icon}${NC}  %-30s  ${DIM}%s${NC}\n" "$skill" "$desc"
        done < <(list_available)

        echo ""

        if ! tool_has_global_control; then
            wait_for_key; return
        fi

        local action
        action=$(gum choose --cursor "▸ " \
            "$S_ENABLE_ALL" \
            "$S_DISABLE_ALL") || true
        [[ -z "$action" ]] && return

        local count=0
        case "$action" in
            "✅"*)
                while read -r s; do
                    [[ "$(get_category "$s")" == "$cat" ]] || continue
                    enable_skill_global "$s" && count=$((count + 1))
                done < <(list_available)
                gum style --foreground 46 "$(printf "$S_N_ENABLED_FMT" "$count")"
                sleep 1 ;;
            "⛔"*)
                while read -r s; do
                    [[ "$(get_category "$s")" == "$cat" ]] || continue
                    disable_skill_global "$s" 2>/dev/null && count=$((count + 1))
                done < <(list_available)
                gum style --foreground 196 "$(printf "$S_N_DISABLED_FMT" "$count")"
                sleep 1 ;;
        esac
    done
}

tui_enable_global() {
    clear
    gum style --bold --foreground 212 "$S_ENABLE_TITLE"
    echo -e "${DIM}${S_HINT_SELECT}${NC}"
    echo ""

    local items=()
    while read -r skill; do
        is_global_active "$skill" && continue
        is_local_skill "$skill" && continue
        local cat desc
        cat=$(get_category "$skill"); desc=$(get_skill_description "$skill")
        items+=("$(printf '%-30s │ @%-8s │ %s' "$skill" "$cat" "$desc")")
    done < <(list_available)

    if [[ ${#items[@]} -eq 0 ]]; then
        gum style --foreground 214 "$S_ALL_ACTIVE"
        sleep 1; return
    fi

    local selected
    selected=$(printf '%s\n' "${items[@]}" | gum filter --no-limit --height 25 --width 0 --placeholder "$S_SEARCH_ENABLE") || true
    [[ -z "$selected" ]] && return

    local count=0
    while IFS= read -r line; do
        local name; name=$(echo "$line" | awk '{print $1}')
        enable_skill_global "$name" && echo -e "  ${GREEN}+${NC} $name" && count=$((count + 1))
    done <<< "$selected"

    echo ""
    gum style --foreground 46 "$(printf "$S_SKILLS_ENABLED_FMT" "$count")"
    wait_for_key
}

tui_disable_global() {
    clear
    gum style --bold --foreground 212 "$S_DISABLE_TITLE"
    echo -e "${DIM}${S_HINT_SELECT}${NC}"
    echo ""

    local items=()
    while read -r skill; do
        is_global_active "$skill" || continue
        is_local_skill "$skill" && continue
        local cat desc
        cat=$(get_category "$skill"); desc=$(get_skill_description "$skill")
        items+=("$(printf '%-30s │ @%-8s │ %s' "$skill" "$cat" "$desc")")
    done < <(list_available)

    if [[ ${#items[@]} -eq 0 ]]; then
        gum style --foreground 214 "$S_NONE_ACTIVE"
        sleep 1; return
    fi

    local selected
    selected=$(printf '%s\n' "${items[@]}" | gum filter --no-limit --height 25 --width 0 --placeholder "$S_SEARCH_DISABLE") || true
    [[ -z "$selected" ]] && return

    local count=0
    while IFS= read -r line; do
        local name; name=$(echo "$line" | awk '{print $1}')
        disable_skill_global "$name" && echo -e "  ${RED}-${NC} $name" && count=$((count + 1))
    done <<< "$selected"

    echo ""
    gum style --foreground 196 "$(printf "$S_SKILLS_DISABLED_FMT" "$count")"
    wait_for_key
}

tui_toggle_category() {
    clear
    gum style --bold --foreground 212 "$S_TOGGLE_TITLE"
    echo ""

    local cats
    cats=$(list_available | while read -r s; do get_category "$s"; done | sort -u)

    local items=()
    for cat in $cats; do
        local total=0 active=0
        while read -r s; do
            [[ "$(get_category "$s")" == "$cat" ]] || continue
            total=$((total + 1)); is_global_active "$s" && active=$((active + 1))
        done < <(list_available)
        items+=("$(printf '@%s  (%s)' "$cat" "$(printf "$S_ACTIVE_FMT" "$active" "$total")")")
    done

    local selected
    selected=$(printf '%s\n' "${items[@]}" | gum choose --cursor "▸ " --height 10) || true
    [[ -z "$selected" ]] && return
    local cat_name
    cat_name=$(echo "$selected" | awk '{print $1}' | sed 's/@//')

    tui_category_detail "$cat_name"
}

# ---- TUI: Search ----

tui_search() {
    clear
    gum style --bold --foreground 212 "$S_SEARCH_TITLE"
    echo ""

    local items=()
    while read -r skill; do
        local icon="○"; is_global_active "$skill" && icon="●"
        local cat desc
        cat=$(get_category "$skill"); desc=$(get_skill_description "$skill")
        items+=("$(printf '%s %-30s │ @%-8s │ %s' "$icon" "$skill" "$cat" "$desc")")
    done < <(list_available)

    local selected
    selected=$(printf '%s\n' "${items[@]}" | gum filter --height 25 --width 0 --placeholder "$S_SEARCH_HINT") || true
    [[ -z "$selected" ]] && return

    local skill_name
    skill_name=$(echo "$selected" | awk '{print $2}')
    [[ -n "$skill_name" ]] && tui_skill_detail "$skill_name"
}

tui_skill_detail() {
    local skill="$1"
    clear

    local desc cat status_text
    desc=$(get_skill_description "$skill")
    cat=$(get_category "$skill")
    status_text="$S_DETAIL_INACTIVE"; is_global_active "$skill" && status_text="$S_DETAIL_ACTIVE"

    gum style --border rounded --border-foreground 212 --padding "1 2" \
        "$(gum style --bold "$skill")" \
        "" \
        "$S_DETAIL_CAT:  @$cat" \
        "$S_DETAIL_GLOBAL:     $status_text" \
        "$S_DETAIL_DESC:  ${desc:-$S_DETAIL_NO_DESC}"

    echo ""

    local has_projects=false
    while IFS= read -r project; do
        [[ -n "$project" ]] || continue
        has_projects=true
        local pname icon
        pname=$(basename "$project")
        icon="○"; is_project_active "$project" "$skill" && icon="●"
        echo -e "  $icon $pname"
    done < <(get_projects)
    $has_projects && echo ""

    if ! tool_has_global_control; then
        wait_for_key; return
    fi

    local options=()
    if is_global_active "$skill"; then
        options+=("$S_DETAIL_DISABLE")
    else
        options+=("$S_DETAIL_ENABLE")
    fi

    local action
    action=$(printf '%s\n' "${options[@]}" | gum choose --cursor "▸ ") || true
    [[ -z "$action" ]] && return

    case "$action" in
        "⛔"*) disable_skill_global "$skill" && gum style --foreground 196 "$S_DISABLED"; sleep 1 ;;
        "✅"*) enable_skill_global "$skill" && gum style --foreground 46 "$S_ENABLED"; sleep 1 ;;
    esac
}

# ---- TUI: Full Status ----

tui_full_status() {
    clear
    gum style --bold --foreground 212 "$S_STATUS_TITLE"
    echo ""

    local lines=() current_cat=""
    while read -r skill; do
        local cat; cat=$(get_category "$skill")
        if [[ "$cat" != "$current_cat" ]]; then
            current_cat="$cat"
            lines+=("" "── @$cat ──────────────────────────────────")
        fi
        local icon="○"; is_global_active "$skill" && icon="●"

        local proj_info=""
        while IFS= read -r project; do
            [[ -n "$project" ]] || continue
            is_project_active "$project" "$skill" && proj_info+=" [$(basename "$project")]"
        done < <(get_projects)

        local desc; desc=$(get_skill_description "$skill")
        lines+=("$(printf '  %s %-28s %-35s%s' "$icon" "$skill" "$desc" "$proj_info")")
    done < <(list_available)

    printf '%s\n' "${lines[@]}" | gum pager --soft-wrap
}

# ---- TUI: Projects ----

tui_project_menu() {
    while true; do
        clear
        local proj_count
        proj_count=$(get_projects | grep -c . 2>/dev/null || echo 0)
        gum style --bold --foreground 212 "$(printf "$S_PROJ_TITLE_FMT" "$proj_count")"
        echo -e "${DIM}${S_ESC_HINT}${NC}"
        echo ""

        local cwd; cwd=$(pwd)
        local cwd_registered=false
        is_project_registered "$cwd" && cwd_registered=true

        local options=()

        if ! $cwd_registered; then
            local cwd_name; cwd_name=$(basename "$cwd")
            options+=("$(printf "$S_PROJ_USE_CWD_FMT" "$cwd_name")")
        fi

        options+=(
            "$S_PROJ_SELECT"
            "$S_PROJ_REGISTER"
            "$S_PROJ_REMOVE"
        )

        local choice
        choice=$(printf '%s\n' "${options[@]}" | gum choose --cursor "▸ " --height 10) || true
        [[ -z "$choice" ]] && return

        case "$choice" in
            "📌"*)  tui_register_and_open "$cwd" ;;
            "📋"*)  tui_select_project ;;
            "➕"*)  tui_add_project ;;
            "🗑️"*)  tui_rm_project ;;
        esac
    done
}

tui_register_and_open() {
    local path="$1"
    register_project "$path"
    local pname; pname=$(basename "$path")
    gum style --foreground 46 "$(printf "$S_PROJ_REGISTERED_FMT" "$pname")"
    sleep 0.5
    tui_project_skills "$path"
}

tui_add_project() {
    clear
    gum style --bold --foreground 212 "$S_REG_TITLE"
    echo ""

    local cwd; cwd=$(pwd)
    local default_val=""
    is_project_registered "$cwd" || default_val="$cwd"

    local path
    path=$(gum input --placeholder "$S_REG_PLACEHOLDER" --value "$default_val" --width 70) || true
    [[ -z "$path" ]] && return

    path="${path/#\~/$HOME}"
    path="$(resolve_path "$path")"

    if [[ ! -d "$path" ]]; then
        gum style --foreground 196 "$(printf "$S_REG_NOT_FOUND_FMT" "$path")"
        sleep 2; return
    fi

    if is_project_registered "$path"; then
        gum style --foreground 214 "$S_REG_ALREADY"
        sleep 1; return
    fi

    register_project "$path"
    gum style --foreground 46 "$(printf "$S_PROJ_REGISTERED_FMT" "$(basename "$path")")"

    if gum confirm "$S_REG_MANAGE_NOW"; then
        tui_project_skills "$path"
    fi
}

tui_rm_project() {
    clear
    gum style --bold --foreground 212 "$S_RM_TITLE"
    echo ""

    local projects; projects=$(get_projects)
    [[ -z "$projects" ]] && { gum style --foreground 214 "$S_RM_NONE"; sleep 1; return; }

    local items=()
    while IFS= read -r p; do
        items+=("$(basename "$p")  ($p)")
    done <<< "$projects"

    local selected
    selected=$(printf '%s\n' "${items[@]}" | gum choose --cursor "▸ ") || true
    [[ -z "$selected" ]] && return
    local project_path
    project_path=$(echo "$selected" | sed 's/.*(\(.*\))/\1/')

    if gum confirm "$(printf "$S_RM_CONFIRM_FMT" "$(basename "$project_path")")"; then
        local tmp; tmp=$(mktemp)
        grep -vxF "$project_path" "$PROJECTS_FILE" > "$tmp" || true
        mv "$tmp" "$PROJECTS_FILE"
        gum style --foreground 196 "$(printf "$S_RM_DONE_FMT" "$(basename "$project_path")")"
        sleep 1
    fi
}

tui_select_project() {
    local projects; projects=$(get_projects)
    [[ -z "$projects" ]] && { gum style --foreground 214 "$S_SEL_NONE"; sleep 2; return; }

    clear
    gum style --bold --foreground 212 "$S_SEL_TITLE"
    echo ""

    local items=()
    while IFS= read -r p; do
        local count; count=$(count_project_skills "$p")
        items+=("$(printf '%-20s  %s  (%d skills)' "$(basename "$p")" "$p" "$count")")
    done <<< "$projects"

    local selected
    selected=$(printf '%s\n' "${items[@]}" | gum choose --cursor "▸ ") || true
    [[ -z "$selected" ]] && return
    local project_path
    project_path=$(echo "$selected" | awk '{print $2}')

    tui_project_skills "$project_path"
}

tui_project_skills() {
    local project="$1"
    local pname; pname=$(basename "$project")

    while true; do
        clear
        local proj_count global_count
        proj_count=$(count_project_skills "$project")
        global_count=$(count_global_active)
        gum style --bold --foreground 212 "$(printf "$S_PS_TITLE_FMT" "$pname")"
        echo -e "${DIM}$project${NC}"
        echo -e "${DIM}$(printf "$S_PS_INFO_FMT" "$proj_count" "$global_count")  ·  ${S_ESC_HINT}${NC}"
        echo ""

        local choice
        choice=$(gum choose --cursor "▸ " --height 10 \
            "$S_PS_VIEW" \
            "$S_PS_ENABLE" \
            "$S_PS_DISABLE" \
            "$S_PS_TOGGLE" \
            "$S_PS_COMPARE") || true
        [[ -z "$choice" ]] && return

        case "$choice" in
            "📋"*)  tui_project_view "$project" ;;
            "✅"*)  tui_project_enable "$project" ;;
            "⛔"*)  tui_project_disable "$project" ;;
            "🔄"*)  tui_project_toggle_cat "$project" ;;
            "📊"*)  tui_project_compare "$project" ;;
        esac
    done
}

tui_project_view() {
    local project="$1" pname; pname=$(basename "$project")
    clear
    gum style --bold --foreground 212 "$(printf "$S_PV_TITLE_FMT" "$pname")"
    echo ""

    local lines=()

    # Global skills (inherited)
    while read -r skill; do
        is_global_active "$skill" || continue
        local cat desc
        cat=$(get_category "$skill"); desc=$(get_skill_description "$skill")
        lines+=("$(printf "● %-27s │ @%-8s │ %-7s │ %s" "$skill" "$cat" "$S_LABEL_GLOBAL" "$desc")")
    done < <(list_available)

    # Project-specific skills (not already global)
    local skills_dir="$project/$TOOL_PROJECT_SUBDIR"
    if [[ -d "$skills_dir" ]]; then
        for entry in "$skills_dir"/*; do
            [[ -L "$entry" ]] || continue
            local name; name=$(basename "$entry")
            is_global_active "$name" && continue
            local cat desc
            cat=$(get_category "$name"); desc=$(get_skill_description "$name")
            lines+=("$(printf "◆ %-27s │ @%-8s │ %-7s │ %s" "$name" "$cat" "$S_LABEL_PROJECT" "$desc")")
        done
    fi

    if [[ ${#lines[@]} -eq 0 ]]; then
        gum style --foreground 214 "$S_PV_NONE"
        wait_for_key; return
    fi

    printf '%s\n' "${lines[@]}" | gum pager --soft-wrap
}

tui_project_enable() {
    local project="$1" pname; pname=$(basename "$project")
    clear
    gum style --bold --foreground 212 "$(printf "$S_PE_TITLE_FMT" "$pname")"
    echo -e "${DIM}${S_HINT_SELECT_SHORT}${NC}"
    echo ""

    local items=()
    while read -r skill; do
        is_project_active "$project" "$skill" && continue
        is_global_active "$skill" && continue
        local cat desc
        cat=$(get_category "$skill"); desc=$(get_skill_description "$skill")
        items+=("$(printf '%-30s │ @%-8s │ %s' "$skill" "$cat" "$desc")")
    done < <(list_available)

    if [[ ${#items[@]} -eq 0 ]]; then
        gum style --foreground 214 "$S_PE_ALL_ACTIVE"; sleep 1; return
    fi

    echo -e "${DIM}${S_PE_INHERITED}${NC}"
    echo ""

    local selected
    selected=$(printf '%s\n' "${items[@]}" | gum filter --no-limit --height 25 --width 0 --placeholder "$S_PE_SEARCH") || true
    [[ -z "$selected" ]] && return

    mkdir -p "$project/$TOOL_PROJECT_SUBDIR"
    local count=0
    while IFS= read -r line; do
        local name; name=$(echo "$line" | awk '{print $1}')
        enable_skill_project "$project" "$name" && echo -e "  ${GREEN}+${NC} $name" && count=$((count + 1))
    done <<< "$selected"

    echo ""
    gum style --foreground 46 "$(printf "$S_PE_DONE_FMT" "$count" "$pname")"
    wait_for_key
}

tui_project_disable() {
    local project="$1" pname; pname=$(basename "$project")
    local skills_dir="$project/$TOOL_PROJECT_SUBDIR"
    clear
    gum style --bold --foreground 212 "$(printf "$S_PD_TITLE_FMT" "$pname")"
    echo ""

    if [[ ! -d "$skills_dir" ]] || [[ -z "$(ls -A "$skills_dir" 2>/dev/null)" ]]; then
        gum style --foreground 214 "$S_PD_NONE"; sleep 1; return
    fi

    local items=()
    for entry in "$skills_dir"/*; do
        [[ -L "$entry" ]] || continue
        local name cat desc
        name=$(basename "$entry"); cat=$(get_category "$name"); desc=$(get_skill_description "$name")
        items+=("$(printf '%-30s │ @%-8s │ %s' "$name" "$cat" "$desc")")
    done

    local selected
    selected=$(printf '%s\n' "${items[@]}" | gum filter --no-limit --height 25 --width 0 --placeholder "$S_PD_SEARCH") || true
    [[ -z "$selected" ]] && return

    local count=0
    while IFS= read -r line; do
        local name; name=$(echo "$line" | awk '{print $1}')
        disable_skill_project "$project" "$name" && echo -e "  ${RED}-${NC} $name" && count=$((count + 1))
    done <<< "$selected"

    echo ""
    gum style --foreground 196 "$(printf "$S_SKILLS_DISABLED_FMT" "$count")"
    wait_for_key
}

tui_project_toggle_cat() {
    local project="$1" pname; pname=$(basename "$project")
    clear
    gum style --bold --foreground 212 "$(printf "$S_PT_TITLE_FMT" "$pname")"
    echo ""

    local cats
    cats=$(list_available | while read -r s; do get_category "$s"; done | sort -u)

    local items=()
    for cat in $cats; do
        local total=0 active=0
        while read -r s; do
            [[ "$(get_category "$s")" == "$cat" ]] || continue
            total=$((total + 1)); is_project_active "$project" "$s" && active=$((active + 1))
        done < <(list_available)
        items+=("$(printf '@%s  (%s)' "$cat" "$(printf "$S_ACTIVE_FMT" "$active" "$total")")")
    done

    local selected
    selected=$(printf '%s\n' "${items[@]}" | gum choose --cursor "▸ " --height 10) || true
    [[ -z "$selected" ]] && return
    local cat_name; cat_name=$(echo "$selected" | awk '{print $1}' | sed 's/@//')

    local action
    action=$(gum choose --cursor "▸ " \
        "$(printf "$S_PT_ENABLE_FMT" "$cat_name")" \
        "$(printf "$S_PT_DISABLE_FMT" "$cat_name")") || true
    [[ -z "$action" ]] && return

    mkdir -p "$project/$TOOL_PROJECT_SUBDIR"
    local count=0
    case "$action" in
        "✅"*)
            while read -r s; do
                [[ "$(get_category "$s")" == "$cat_name" ]] || continue
                enable_skill_project "$project" "$s" && count=$((count + 1))
            done < <(list_available)
            gum style --foreground 46 "$(printf "$S_PT_ENABLED_FMT" "$count" "$pname")"
            ;;
        "⛔"*)
            while read -r s; do
                [[ "$(get_category "$s")" == "$cat_name" ]] || continue
                disable_skill_project "$project" "$s" 2>/dev/null && count=$((count + 1))
            done < <(list_available)
            gum style --foreground 196 "$(printf "$S_PT_DISABLED_FMT" "$count" "$pname")"
            ;;
        *) return ;;
    esac
    sleep 1
}

tui_project_compare() {
    local project="$1" pname; pname=$(basename "$project")
    clear
    gum style --bold --foreground 212 "$(printf "$S_PC_TITLE_FMT" "$pname")"
    echo ""

    local lines=()
    lines+=("$(printf '%-30s  %-8s  %-8s' 'SKILL' 'GLOBAL' "$pname")")
    lines+=("$(printf '%-30s  %-8s  %-8s' '─────' '──────' '──────')")

    local diffs=0
    while read -r skill; do
        local g="OFF" p="OFF"
        is_global_active "$skill" && g=" ON"
        is_project_active "$project" "$skill" && p=" ON"
        [[ "$g" == "$p" ]] && continue
        lines+=("$(printf '%-30s  %-8s  %-8s' "$skill" "$g" "$p")")
        diffs=$((diffs + 1))
    done < <(list_available)

    [[ $diffs -eq 0 ]] && lines+=("  $S_PC_IDENTICAL")

    printf '%s\n' "${lines[@]}" | gum pager --soft-wrap
}

# ---- CLI (non-interactive) ----

# List all tools that have separate global directories (not source-direct)
all_global_tools() {
    local all="amp augment claude cline continue copilot cursor factory gemini goose kilo kiro opencode roo trae vscode zed"
    for t in $all; do echo "$t"; done
}

# Run enable/disable across multiple tools, temporarily switching context
with_tools() {
    local action="$1" skill="$2"
    shift 2
    local tools=("$@")
    local saved_tool="$TOOL_NAME"
    local saved_global="$GLOBAL_SKILLS"
    local saved_subdir="$TOOL_PROJECT_SUBDIR"
    local total=0

    for t in "${tools[@]}"; do
        TOOL_NAME="$t"
        apply_tool
        tool_has_global_control || continue

        local count=0
        while read -r s; do
            if [[ "$action" == "enable" ]]; then
                enable_skill_global "$s" && count=$((count + 1))
            else
                disable_skill_global "$s" 2>/dev/null && count=$((count + 1))
            fi
        done < <(expand_target "$skill")

        if [[ $count -gt 0 ]]; then
            local display; display=$(tool_display_name "$t")
            if [[ "$action" == "enable" ]]; then
                echo -e "  ${GREEN}+${NC} ${BOLD}$display${NC}: $count skill(s)"
            else
                echo -e "  ${RED}-${NC} ${BOLD}$display${NC}: $count skill(s)"
            fi
            total=$((total + count))
        fi
    done

    # Restore original context
    TOOL_NAME="$saved_tool"
    GLOBAL_SKILLS="$saved_global"
    TOOL_PROJECT_SUBDIR="$saved_subdir"

    echo ""
    if [[ "$action" == "enable" ]]; then
        echo -e "$(printf "$S_CLI_ENABLED_FMT" "$total") ${DIM}(${#tools[@]} tools)${NC}"
    else
        echo -e "$(printf "$S_CLI_DISABLED_FMT" "$total") ${DIM}(${#tools[@]} tools)${NC}"
    fi
}

cli_enable() {
    if ! tool_has_global_control; then
        echo -e "${RED}${S_CLI_NO_GLOBAL}${NC}"; return 1
    fi
    local count=0
    while read -r s; do
        enable_skill_global "$s" && echo -e "  ${GREEN}+${NC} $s" && count=$((count + 1))
    done < <(expand_target "$1")
    echo -e "\n$(printf "$S_CLI_ENABLED_FMT" "$count")"
}

cli_disable() {
    if ! tool_has_global_control; then
        echo -e "${RED}${S_CLI_NO_GLOBAL}${NC}"; return 1
    fi
    local count=0
    while read -r s; do
        disable_skill_global "$s" 2>/dev/null && echo -e "  ${RED}-${NC} $s" && count=$((count + 1))
    done < <(expand_target "$1")
    echo -e "\n$(printf "$S_CLI_DISABLED_FMT" "$count")"
}

cli_status() {
    local filter_cat="${1:-}"
    local projects=()
    while IFS= read -r line; do
        [[ -n "$line" ]] && projects+=("$line")
    done < <(get_projects)

    local tool_display; tool_display=$(tool_display_name "$TOOL_NAME")
    echo -e "${DIM}Target: ${tool_display}${NC}"
    echo ""

    printf "${BOLD}%-30s  %-8s" "SKILL" "GLOBAL"
    if [[ ${#projects[@]} -gt 0 ]]; then
        for p in "${projects[@]}"; do printf "  %-12s" "$(basename "$p")"; done
    fi
    printf "${NC}\n"

    local current_cat=""
    while read -r skill; do
        local cat; cat="$(get_category "$skill")"
        [[ -n "$filter_cat" && "$cat" != "$filter_cat" ]] && continue

        if [[ "$cat" != "$current_cat" ]]; then
            current_cat="$cat"
            echo -e "\n${BOLD}${CYAN}@${cat}${NC}"
        fi

        local gs
        if is_local_skill "$skill"; then gs="${BLUE}local${NC}"
        elif is_global_active "$skill"; then gs="${GREEN}  on${NC}"
        else gs="${DIM} off${NC}"
        fi

        printf "  %-28s  %b" "$skill" "$gs"
        if [[ ${#projects[@]} -gt 0 ]]; then
            for p in "${projects[@]}"; do
                if is_project_active "$p" "$skill"; then printf "    ${GREEN}on${NC}          "
                else printf "    ${DIM}-${NC}           "
                fi
            done
        fi
        printf "\n"
    done < <(list_available)
}

cli_categories() {
    local cats
    cats=$(list_available | while read -r s; do get_category "$s"; done | sort -u)
    echo -e "${BOLD}${S_CLI_CATS}${NC}\n"
    for cat in $cats; do
        local total=0 active=0
        while read -r s; do
            [[ "$(get_category "$s")" == "$cat" ]] || continue
            total=$((total + 1)); is_global_active "$s" && active=$((active + 1))
        done < <(list_available)
        printf "  ${CYAN}@%-12s${NC} %3d skills (%d ${S_CLI_ACTIVE})\n" "$cat" "$total" "$active"
    done
}

cli_info() {
    local skill="$1"
    local desc cat
    desc=$(get_skill_description "$skill"); cat=$(get_category "$skill")

    if [[ ! -d "$SKILLS_SOURCE/$skill" ]]; then
        echo -e "${RED}$(printf "$S_CLI_NOT_FOUND_FMT" "$skill")${NC}"; return 1
    fi

    echo -e "${BOLD}$skill${NC}  @$cat"
    [[ -n "$desc" ]] && echo -e "${DIM}$desc${NC}"
    echo ""

    if is_global_active "$skill"; then echo -e "  Global: ${GREEN}on${NC}"
    else echo -e "  Global: ${DIM}off${NC}"
    fi

    while IFS= read -r project; do
        [[ -n "$project" ]] || continue
        local pname; pname=$(basename "$project")
        if is_project_active "$project" "$skill"; then
            echo -e "  $pname: ${GREEN}on${NC}"
        fi
    done < <(get_projects)
}

cli_project_enable() {
    local project count=0
    project="$(resolve_path "$1")"
    register_project "$project"
    while read -r s; do
        enable_skill_project "$project" "$s" && echo -e "  ${GREEN}+${NC} $s" && count=$((count + 1))
    done < <(expand_target "$2")
    echo -e "\n$(printf "$S_CLI_PE_DONE_FMT" "$count" "$(basename "$project")")"
}

cli_project_disable() {
    local project count=0
    project="$(resolve_path "$1")"
    while read -r s; do
        disable_skill_project "$project" "$s" && echo -e "  ${RED}-${NC} $s" && count=$((count + 1))
    done < <(expand_target "$2")
    echo -e "\n$(printf "$S_CLI_PD_DONE_FMT" "$count" "$(basename "$project")")"
}

# ---- npm Sync ----

NPM_MANIFEST="$CONFIG_DIR/npm-manifest.json"
NPM_GLOBAL_ROOT=""

get_npm_root() {
    [[ -n "$NPM_GLOBAL_ROOT" ]] && return
    NPM_GLOBAL_ROOT=$(npm root -g 2>/dev/null) || NPM_GLOBAL_ROOT=""
}

# Scan npm global packages for skills/ directories with SKILL.md files
discover_npm_skills() {
    get_npm_root
    [[ -n "$NPM_GLOBAL_ROOT" && -d "$NPM_GLOBAL_ROOT" ]] || return

    # Scan top-level and scoped packages
    local pkg_dirs=()
    for d in "$NPM_GLOBAL_ROOT"/*/; do
        [[ -d "$d" ]] && pkg_dirs+=("$d")
    done
    for d in "$NPM_GLOBAL_ROOT"/@*/*/; do
        [[ -d "$d" ]] && pkg_dirs+=("$d")
    done

    for pkg_dir in "${pkg_dirs[@]}"; do
        [[ -d "$pkg_dir/skills" ]] || continue
        local pkg_name
        pkg_name=$(basename "$pkg_dir")
        # For scoped packages, include scope
        local parent; parent=$(basename "$(dirname "$pkg_dir")")
        if [[ "$parent" == @* ]]; then
            pkg_name="$parent/$pkg_name"
        fi

        for skill_dir in "$pkg_dir/skills"/*/; do
            [[ -f "$skill_dir/SKILL.md" ]] || continue
            local skill_name; skill_name=$(basename "$skill_dir")
            echo "$pkg_name|$skill_name|${skill_dir%/}"
        done
    done
}

# Sync npm skills: create symlinks for new, remove broken ones
cli_sync() {
    echo -e "${DIM}$S_SYNC_SCANNING${NC}"
    mkdir -p "$SKILLS_SOURCE"

    local linked=0 removed=0

    # Phase 1: Discover and link new npm skills
    while IFS='|' read -r pkg_name skill_name skill_path; do
        [[ -n "$pkg_name" ]] || continue
        local target="$SKILLS_SOURCE/$skill_name"

        if [[ -L "$target" ]]; then
            # Already a symlink — update if target changed
            local current; current=$(readlink "$target")
            local expected="${skill_path%/}"
            if [[ "$current" != "$expected" ]]; then
                ln -sfn "$expected" "$target"
                echo -e "  ${GREEN}↻${NC} $skill_name ${DIM}($pkg_name)${NC}"
                linked=$((linked + 1))
            fi
        elif [[ -d "$target" ]]; then
            # Real directory exists — skip (manual install takes precedence)
            continue
        else
            # New skill — create symlink
            ln -sfn "${skill_path%/}" "$target"
            echo -e "  ${GREEN}+${NC} $skill_name ${DIM}($pkg_name)${NC}"
            linked=$((linked + 1))
        fi
    done < <(discover_npm_skills)

    # Phase 2: Clean up broken symlinks (from uninstalled packages)
    for entry in "$SKILLS_SOURCE"/*; do
        [[ -L "$entry" && ! -e "$entry" ]] || continue
        local name; name=$(basename "$entry")
        rm "$entry"
        echo -e "  ${RED}-${NC} $name ${DIM}(orphan)${NC}"
        removed=$((removed + 1))
    done

    if [[ $linked -eq 0 && $removed -eq 0 ]]; then
        echo -e "${GREEN}$S_SYNC_UPTODATE${NC}"
    else
        echo ""
        echo -e "$(printf "$S_SYNC_DONE_FMT" "$linked" "$removed")"
    fi

    # Save manifest
    save_npm_manifest
}

save_npm_manifest() {
    local manifest="$NPM_MANIFEST"
    echo "{" > "$manifest"
    echo '  "skills": {' >> "$manifest"
    local first=true
    for entry in "$SKILLS_SOURCE"/*/; do
        local name; name=$(basename "$entry")
        [[ -L "$SKILLS_SOURCE/$name" ]] || continue
        local link_target; link_target=$(readlink "$SKILLS_SOURCE/$name")
        [[ "$link_target" == *node_modules* ]] || continue
        if $first; then first=false; else echo "," >> "$manifest"; fi
        printf '    "%s": "%s"' "$name" "$link_target" >> "$manifest"
    done
    echo "" >> "$manifest"
    echo "  }" >> "$manifest"
    echo "}" >> "$manifest"
}

cli_npm_install() {
    local pkg="$1"
    echo -e "$(printf "$S_SYNC_INSTALL_FMT" "$pkg")"
    npm i -g "$pkg" 2>&1 || { echo -e "${RED}npm install failed${NC}"; return 1; }
    echo ""
    cli_sync
}

cli_npm_uninstall() {
    local pkg="$1"
    echo -e "$(printf "$S_SYNC_UNINSTALL_FMT" "$pkg")"
    npm uninstall -g "$pkg" 2>&1 || { echo -e "${RED}npm uninstall failed${NC}"; return 1; }
    echo ""
    cli_sync
}

usage() {
    echo -e "${BOLD}${S_USAGE_TITLE}${NC}"
    echo ""
    echo -e "${BOLD}${S_USAGE_USE}${NC}"
    echo "  skills-mgr                             $S_USAGE_TUI"
    echo "  skills-mgr <command> [options]          $S_USAGE_CLI"
    echo ""
    echo -e "${BOLD}${S_USAGE_DIRECT}${NC}"
    echo "  status [category]                      $S_USAGE_STATUS"
    echo "  enable|on  <skill|@cat> [--all|--tools] $S_USAGE_ENABLE"
    echo "  disable|off <skill|@cat> [--all|--tools] $S_USAGE_DISABLE"
    echo "  info <skill>                           $S_USAGE_INFO"
    echo "  categories|cats                        $S_USAGE_CATS"
    echo "  projects|ps                            $S_USAGE_PROJECTS"
    echo "  project add [path]                     $S_USAGE_PROJ_ADD"
    echo "  project rm <path>                      $S_USAGE_PROJ_RM"
    echo "  project status [path]                  $S_USAGE_PROJ_STATUS"
    echo "  project enable [path] <skill|@cat>     $S_USAGE_PROJ_ENABLE"
    echo "  project disable [path] <skill|@cat>    $S_USAGE_PROJ_DISABLE"
    echo "  sync                                   Sync skills from npm packages"
    echo "  install <package>                      npm install + sync"
    echo "  uninstall <package>                    npm uninstall + sync"
    echo "  tool [name]                            $S_USAGE_TOOL"
    echo "  lang <en|pt>                           $S_USAGE_LANG"
    echo ""
    echo -e "${BOLD}${S_USAGE_EXAMPLES}${NC}"
    echo -e "  skills-mgr                                 ${DIM}${S_USAGE_EX_TUI}${NC}"
    echo -e "  skills-mgr off @recipe                     ${DIM}${S_USAGE_EX_OFF}${NC}"
    echo -e "  skills-mgr project add                     ${DIM}${S_USAGE_EX_ADD}${NC}"
    echo -e "  skills-mgr project enable . @gws           ${DIM}${S_USAGE_EX_GWS}${NC}"
    echo -e "  skills-mgr info gws-gmail                  ${DIM}${S_USAGE_EX_INFO}${NC}"
    echo -e "  skills-mgr tool gemini                     ${DIM}${S_USAGE_EX_TOOL}${NC}"
}

# ---- Main ----

main() {
init

# First run: prompt for language
if [[ ! -f "$LANG_FILE" && "${1:-}" == "" ]]; then
    tui_select_language
fi

case "${1:-}" in
    "")              tui_main_menu ;;
    status|s)        cli_status "${2:-}" ;;
    enable|on)
        [[ -n "${2:-}" ]] || { echo "Usage: skills-mgr enable <skill|@cat> [--all|--tools t1,t2]"; exit 1; }
        if [[ "${3:-}" == "--all" ]]; then
            local _tools=(); while read -r _t; do _tools+=("$_t"); done < <(all_global_tools)
            with_tools enable "$2" "${_tools[@]}"
        elif [[ "${3:-}" == "--tools" ]]; then
            [[ -n "${4:-}" ]] || { echo "Usage: skills-mgr enable <skill> --tools claude,cursor"; exit 1; }
            local _tools; IFS=',' read -ra _tools <<< "$4"
            with_tools enable "$2" "${_tools[@]}"
        else
            cli_enable "$2"
        fi
        ;;
    disable|off)
        [[ -n "${2:-}" ]] || { echo "Usage: skills-mgr disable <skill|@cat> [--all|--tools t1,t2]"; exit 1; }
        if [[ "${3:-}" == "--all" ]]; then
            local _tools=(); while read -r _t; do _tools+=("$_t"); done < <(all_global_tools)
            with_tools disable "$2" "${_tools[@]}"
        elif [[ "${3:-}" == "--tools" ]]; then
            [[ -n "${4:-}" ]] || { echo "Usage: skills-mgr disable <skill> --tools claude,cursor"; exit 1; }
            local _tools; IFS=',' read -ra _tools <<< "$4"
            with_tools disable "$2" "${_tools[@]}"
        else
            cli_disable "$2"
        fi
        ;;
    info|i)          [[ -n "${2:-}" ]] || { echo "Usage: skills-mgr info <skill>"; exit 1; }; cli_info "$2" ;;
    categories|cats) cli_categories ;;
    sync)            cli_sync ;;
    install)
        [[ -n "${2:-}" ]] || { echo "Usage: skills-mgr install <package>"; exit 1; }
        cli_npm_install "$2"
        ;;
    uninstall)
        [[ -n "${2:-}" ]] || { echo "Usage: skills-mgr uninstall <package>"; exit 1; }
        cli_npm_uninstall "$2"
        ;;
    tool|--tool)
        if [[ -n "${2:-}" ]]; then
            save_tool "$2"
            echo "Target tool: $(tool_display_name "$2")"
        else
            echo "Target tool: $(tool_display_name "$TOOL_NAME")"
            echo ""
            echo "Available: amp, augment, claude, cline, codex, continue, copilot, cursor, factory, gemini, goose, kilo, kiro, opencode, roo, trae, vscode, windsurf, zed"
            echo "Usage: skills-mgr tool <name>"
        fi
        ;;
    lang|--lang)
        [[ -n "${2:-}" ]] || { echo "Usage: skills-mgr lang <en|pt>"; exit 1; }
        save_lang "$2"
        echo "Language set to: $2"
        ;;
    projects|ps)
        while IFS= read -r p; do
            [[ -n "$p" ]] || continue
            printf "  ${CYAN}%-20s${NC} %s ${DIM}(%d skills)${NC}\n" "$(basename "$p")" "$p" "$(count_project_skills "$p")"
        done < <(get_projects)
        ;;
    project|p)
        case "${2:-}" in
            add)
                p="$(resolve_path "${3:-.}")"
                [[ -d "$p" ]] || { echo "$(printf "$S_CLI_NOT_DIR_FMT" "$p")"; exit 1; }
                register_project "$p"
                echo -e "${GREEN}$(printf "$S_CLI_REGISTERED_FMT" "$p")${NC}"
                ;;
            rm|remove)
                [[ -n "${3:-}" ]] || { echo "Usage: skills-mgr project rm <path>"; exit 1; }
                p="$(resolve_path "$3")"
                tmp=$(mktemp); grep -vxF "$p" "$PROJECTS_FILE" > "$tmp" || true; mv "$tmp" "$PROJECTS_FILE"
                echo -e "${RED}$(printf "$S_CLI_REMOVED_FMT" "$p")${NC}"
                ;;
            enable|on)
                if [[ -n "${4:-}" ]]; then
                    cli_project_enable "$3" "$4"
                elif [[ -n "${3:-}" ]]; then
                    cli_project_enable "." "$3"
                else
                    echo "Usage: skills-mgr project enable [path] <skill|@cat>"; exit 1
                fi
                ;;
            disable|off)
                if [[ -n "${4:-}" ]]; then
                    cli_project_disable "$3" "$4"
                elif [[ -n "${3:-}" ]]; then
                    cli_project_disable "." "$3"
                else
                    echo "Usage: skills-mgr project disable [path] <skill|@cat>"; exit 1
                fi
                ;;
            status|s)
                p="$(resolve_path "${3:-.}")"
                echo -e "${BOLD}$(basename "$p")${NC} ${DIM}($(count_project_skills "$p") skills)${NC}"
                for e in "$p/$TOOL_PROJECT_SUBDIR"/*; do
                    [[ -e "$e" ]] || continue
                    n=$(basename "$e")
                    printf "  ${GREEN}●${NC} %-28s  @%-10s  ${DIM}%s${NC}\n" "$n" "$(get_category "$n")" "$(get_skill_description "$n" | cut -c1-40)"
                done
                ;;
            *)
                echo "Usage: skills-mgr project <add|rm|status|enable|disable>"; exit 1 ;;
        esac
        ;;
    help|--help|-h) usage ;;
    *)              echo -e "${RED}$(printf "$S_CLI_UNKNOWN_FMT" "$1")${NC}"; usage; exit 1 ;;
esac
}

main "$@"
