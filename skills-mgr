        "Augment Code" \
        "Claude Code" \
        "Cline" \
        "Codex" \
        "Continue" \
        "Cursor" \
        "Factory/Droid" \
        "Gemini CLI" \
        "GitHub Copilot" \
        "Goose" \
        "Kilo Code" \
        "Kiro" \
        "OpenCode" \
        "Roo Code" \
        "Trae" \
        "VS Code" \
        "Windsurf" \
