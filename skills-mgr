}

# ---- TUI: Main Menu ----

tui_main_menu() {
    while true; do
        clear
        header
        echo ""

        local cwd; cwd=$(pwd)
        local cwd_name; cwd_name=$(basename "$cwd")
        local options=()

        if is_project_registered "$cwd"; then
            local pcount; pcount=$(count_project_skills "$cwd")
            options+=("$(printf "$S_MENU_CWD_FMT" "$cwd_name" "$pcount")")
        fi

        options+=(
            "$S_MENU_GLOBAL"
            "$S_MENU_PROJECT"
            "$S_MENU_SEARCH"
            "$S_MENU_STATUS"
            "$S_MENU_TOOL"
            "$S_MENU_LANG"
            "$S_MENU_EXIT"
        )

        local choice
        choice=$(printf '%s\n' "${options[@]}" | gum choose --cursor "▸ " --height 13) || true
        [[ -z "$choice" ]] && exit 0

        case "$choice" in
            "📌"*)  tui_project_skills "$cwd" ;;
            "🔧"*)  tui_global_skills ;;
            "📁"*)  tui_project_menu ;;
            "🔍"*)  tui_search ;;
            "📊"*)  tui_full_status ;;
            "⚙️"*)  tui_select_tool ;;
            "🌐"*)  tui_select_language ;;
